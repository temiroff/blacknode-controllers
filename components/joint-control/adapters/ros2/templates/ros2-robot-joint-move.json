{
  "kind": "blacknode.workflow",
  "schema_version": 1,
  "name": "Move a Robot Joint",
  "saved_at": "2026-07-21T00:00:00",
  "entrypoint": {
    "node_id": "dashboard",
    "port": "dashboard"
  },
  "metadata": {
    "template": true,
    "description": "Reads a robot's live joint positions and moves one joint, with a before/after dashboard. SAFE BY DEFAULT: it only previews and sends nothing to the robot until you set armed=true on the move node. WORKS WITH NO ROBOT: the sim_robot node publishes a SIMULATED /joint_states so you can see the whole flow with no hardware. Its positions are fixed, so a simulated 'after' will not actually change \u2014 it shows the path, not real motion. FOR A REAL ROBOT: set sim_robot action=stop (or delete it) so your robot's own /joint_states is used, pick a joint name from the joint names output, set the target position, check the preview, then set armed=true.",
    "color": "#2e9fe6",
    "required_packages": [
      "blacknode-controllers",
      "blacknode-ros2"
    ]
  },
