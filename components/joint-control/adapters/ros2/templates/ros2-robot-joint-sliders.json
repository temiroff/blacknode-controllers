  "metadata": {
    "template": true,
    "description": "Plug in the robot, pick its profile, and drive every joint from live sliders. ROS2Status starts the rosbridge; the Robot node launches the profile's driver so the robot PUBLISHES /joint_states and SUBSCRIBES /joint_commands; ROS2JointState reads the live pose; and ROS2JointSliders builds one slider per joint. Go Live, tick Arm on the sliders node, and drag a slider to move that joint in real time. Motion stays disarmed until you enable it. Set the topics on the Robot node to match your robot.",
    "color": "#2e9fe6",
    "required_packages": [
      "blacknode-controllers",
      "blacknode-ros2",
      "blacknode-robot"
    ]
  },
